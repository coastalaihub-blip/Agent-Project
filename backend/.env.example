# ================================================================
# BACKEND ENVIRONMENT CONFIGURATION
# Copy this to .env and fill in your actual credentials
# ================================================================

# ─── SUPABASE (Required) ────────────────────────────────────────
# Get these from: Supabase Project Settings → API
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ─── DEEPGRAM STT (Required) ────────────────────────────────────
# Get from: https://console.deepgram.com/keys
DEEPGRAM_API_KEY=your_deepgram_api_key_here

# ─── EXOTEL VOICE PROVIDER (Required unless using Ozonetel) ─────
# Get from: Exotel Dashboard → Integrations → API Settings
EXOTEL_SID=your_exotel_sid
EXOTEL_TOKEN=your_exotel_token
EXOTEL_VIRTUAL_NUMBER=+919080451001

# ─── OZONETEL VOICE PROVIDER (Alternative to Exotel) ────────────
# Get from: Ozonetel Dashboard → API Settings
OZONETEL_API_KEY=your_ozonetel_api_key

# ─── ELEVENLABS TTS (Required) ──────────────────────────────────
# Get from: https://elevenlabs.io/app/api
ELEVENLABS_API_KEY=your_elevenlabs_key
# Voice IDs configured per vertical (optional, auto-selected if not provided)
ELEVENLABS_CLINIC_VOICE_ID=your_clinic_voice_id
ELEVENLABS_CALL_CENTER_VOICE_ID=your_call_center_voice_id

# ─── SERVICE URLS (Required) ────────────────────────────────────
# These point to other services running locally (or deployed)
AGENT_SERVICE_URL=http://localhost:8001
TTS_SERVICE_URL=http://localhost:8002
KNOWLEDGE_SERVICE_URL=http://localhost:8003

# ─── EXPO PUSH NOTIFICATIONS (Optional) ─────────────────────────
# Disable if you want to skip push notifications during testing
EXPO_PUSH_ENABLED=true

# ─── DEVELOPMENT ────────────────────────────────────────────────
# FastAPI log level: 'debug', 'info', 'warning', 'error'
LOG_LEVEL=info
