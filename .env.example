# ─── Supabase ───────────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key
SUPABASE_ANON_KEY=your-anon-key

# ─── Claude / Anthropic ────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ─── Pinecone ──────────────────────────────────────────
PINECONE_API_KEY=pcsk_...
PINECONE_INDEX_NAME=ai-agent-platform

# ─── ElevenLabs ────────────────────────────────────────
ELEVENLABS_API_KEY=...
ELEVENLABS_CLINIC_VOICE_ID=...
ELEVENLABS_CALL_CENTER_VOICE_ID=...

# ─── Deepgram ──────────────────────────────────────────
DEEPGRAM_API_KEY=...

# ─── Telephony (whichever activates first) ─────────────
EXOTEL_API_KEY=...
EXOTEL_API_TOKEN=...
EXOTEL_SID=...
OZONETEL_API_KEY=...
OZONETEL_USERNAME=...

# ─── App ───────────────────────────────────────────────
APP_ENV=development
LOG_LEVEL=INFO
