# ─── Supabase ───────────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key
SUPABASE_ANON_KEY=your-anon-key

# ─── Claude / Anthropic ────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ─── Pinecone ──────────────────────────────────────────
PINECONE_API_KEY=pcsk_...
PINECONE_INDEX_NAME=ai-agent-platform

# ─── ElevenLabs ────────────────────────────────────────
ELEVENLABS_API_KEY=...
ELEVENLABS_CLINIC_VOICE_ID=...
ELEVENLABS_CALL_CENTER_VOICE_ID=...

# ─── Deepgram ──────────────────────────────────────────
DEEPGRAM_API_KEY=...

# ─── Telephony (whichever activates first) ─────────────
EXOTEL_API_KEY=...
EXOTEL_API_TOKEN=...
EXOTEL_SID=...
EXOTEL_TOKEN=...
EXOTEL_VIRTUAL_NUMBER=...
OZONETEL_API_KEY=...
OZONETEL_USERNAME=...

# ─── Internal Service URLs ─────────────────────────────
AGENT_SERVICE_URL=http://localhost:8001
TTS_SERVICE_URL=http://localhost:8002

# ─── Mobile Push Notifications (Expo) ──────────────────
EXPO_PUSH_ENABLED=true

# ─── Voicebot WebSocket ────────────────────────────────
# Public WSS URL for Exotel Voicebot Applet configuration
VOICEBOT_WS_URL=wss://your-domain.com/ws/voicebot

# ─── App ───────────────────────────────────────────────
APP_ENV=development
LOG_LEVEL=INFO
